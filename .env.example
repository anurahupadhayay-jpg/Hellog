# ── Telegram Bot Configuration ───────────────────────────────────────────────
# Get these from https://my.telegram.org
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Admin Configuration ──────────────────────────────────────────────────────
# Main admin Telegram user ID (get it from @userinfobot)
MAIN_ADMIN_ID=7682705436

# Secret credentials for emergency admin access
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_to_a_secure_password

# ── Google OAuth 2.0 Configuration ──────────────────────────────────────────
# Path to your client_secrets.json from Google Cloud Console
CLIENT_SECRETS_PATH=credentials/client_secrets.json

# OAuth redirect URI (for local testing use localhost)
OAUTH_REDIRECT_URI=http://localhost:8080/oauth2callback

# ── Monetization & Payment Configuration ─────────────────────────────────────
# UPIGateway API Key for automated payments
UPIGATEWAY_API_KEY=your_upigateway_api_key_here

# Fallback cost per hour (now using tier-based plans)
COST_PER_HOUR=1.0

# Free minutes for new users (0 to disable)
DEFAULT_FREE_MINUTES=30

# Warning threshold in minutes (warn user when balance below this)
WARNING_THRESHOLD_MINUTES=10

# ── Upload Configuration ─────────────────────────────────────────────────────
# Maximum file size in bytes (2GB = 2147483648)
MAX_FILE_SIZE=2147483648

# Upload chunk size in bytes (256KB = 262144)
UPLOAD_CHUNK_SIZE=262144

# Maximum retry attempts for failed uploads
MAX_RETRIES=3

# Queue processing interval in seconds
QUEUE_PROCESS_INTERVAL=5

# ── Logging Configuration ────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_FREE_TRIAL=true
ENABLE_ADMIN_BROADCAST=true
